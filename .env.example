# Copy this file to .env and adjust as needed. NEVER commit .env.
#
# Two connection strings, on purpose:
#
#   DATABASE_URL  → the RESTRICTED `hris_app` role. Used by @hris/database at
#                   RUNTIME (the Prisma client the app imports). It cannot
#                   UPDATE/DELETE the audit log — that's the compliance guarantee.
#
#   DIRECT_URL    → the `postgres` OWNER role. Used only by Prisma Migrate and
#                   Prisma Studio to create/alter tables and run privileged SQL.
#
# Prisma reads `directUrl` from the datasource for migrations and `url` for the
# runtime client. Host/port/db match docker-compose.yml.
DATABASE_URL="postgresql://hris_app:hris_app_pw@localhost:5433/hris?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/hris?schema=public"
